generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgresql://postgres:[YOUR-PASSWORD]@db.qomuoskabtpclwsvsxig.supabase.co:5432/postgres")
}

// Пользователь системы
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  adAccounts AdAccount[]
}

// Рекламный аккаунт Facebook
model AdAccount {
  id             String   @id @default(cuid())
  userId         String
  accountId      String   @unique // Facebook account ID (act_XXX)
  name           String
  timezone       String   @default("UTC")
  accessToken    String   @map("access_token") // Зашифрованный токен
  tokenExpiresAt DateTime @map("token_expires_at")
  status         String   @default("active") // active, expired, revoked
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user           User     @relation(fields: [userId], references: [id])
  campaigns      Campaign[]
  adSets         AdSet[]
  ads            Ad[]
  metrics        MetricSnapshot[]
  rules          Rule[]
  ruleExecutions RuleExecution[]
  aiRecommendations AIRecommendation[]
  aiActions      AIAction[]
  approveData    ApproveData[]
  
  @@index([userId])
}

// Кампания
model Campaign {
  id           String   @id @default(cuid())
  adAccountId  String
  campaignId   String   @unique // Facebook campaign ID
  name         String
  status       String   // ACTIVE, PAUSED, DELETED
  objective    String?
  createdTime  DateTime @map("created_time")
  updatedTime  DateTime @map("updated_time")
  createdAt    DateTime @default(now())
  
  adAccount    AdAccount @relation(fields: [adAccountId], references: [id])
  adSets       AdSet[]
  
  @@index([adAccountId])
  @@index([status])
}

// Группа объявлений (Ad Set)
model AdSet {
  id          String   @id @default(cuid())
  adAccountId String
  campaignId  String
  adSetId     String   @unique // Facebook ad set ID
  name        String
  status      String   // ACTIVE, PAUSED, DELETED
  budget      Float?
  bidStrategy String?  // LOWEST_COST_WITH_BID_CAP, COST_CAP, etc.
  createdTime DateTime @map("created_time")
  updatedTime DateTime @map("updated_time")
  createdAt   DateTime @default(now())
  
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id])
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  ads         Ad[]
  
  @@index([adAccountId])
  @@index([campaignId])
  @@index([status])
}

// Объявление
model Ad {
  id          String   @id @default(cuid())
  adAccountId String
  adSetId     String
  adId        String   @unique // Facebook ad ID
  name        String
  status      String   // ACTIVE, PAUSED, DELETED
  creativeUrl String?  @map("creative_url")
  createdTime DateTime @map("created_time")
  updatedTime DateTime @map("updated_time")
  createdAt   DateTime @default(now())
  
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id])
  adSet       AdSet     @relation(fields: [adSetId], references: [id])
  
  @@index([adAccountId])
  @@index([adSetId])
  @@index([status])
}

// Снимок метрик (кэш статистики)
model MetricSnapshot {
  id           String   @id @default(cuid())
  adAccountId  String
  entityType   String   // account, campaign, adset, ad
  entityId     String   // ID сущности
  entityName   String   // Имя для отображения
  
  // Метрики из Facebook
  spend        Float    @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  ctr          Float    @default(0) // Click-through rate
  cpc          Float    @default(0) // Cost per click
  cpm          Float    @default(0) // Cost per 1000 impressions
  
  // Конверсии
  leads        Int      @default(0)
  conversions  Int      @default(0)
  cpl          Float    @default(0) // Cost per lead
  cpa          Float    @default(0) // Cost per action/conversion
  
  // Доходность
  revenue      Float    @default(0)
  roas         Float    @default(0) // Return on ad spend
  roi          Float    @default(0) // Return on investment
  
  // Аппрувы (ручной ввод)
  approves     Int      @default(0)
  cpas         Float    @default(0) // Cost per approve
  
  date         DateTime // Дата снимка
  createdAt    DateTime @default(now())
  
  adAccount    AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([adAccountId, entityType, entityId])
  @@index([adAccountId, date])
  @@index([entityType, entityId, date])
}

// Правило автоматизации
model Rule {
  id              String   @id @default(cuid())
  adAccountId     String
  name            String
  description     String?
  entityType      String   // ad, adset, campaign
  condition       String   // JSON с условием
  action          String   // pause, enable, budget_change, bid_change
  actionParams    String?  // JSON с параметрами действия
  threshold       Float?
  cooldownMinutes Int      @default(60)
  isActive        Boolean  @default(true)
  lastExecutedAt  DateTime? @map("last_executed_at")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  adAccount       AdAccount       @relation(fields: [adAccountId], references: [id])
  ruleExecutions  RuleExecution[]
  
  @@index([adAccountId])
  @@index([isActive])
}

// Лог выполнения правила
model RuleExecution {
  id           String   @id @default(cuid())
  ruleId       String
  adAccountId  String
  entityType   String
  entityId     String
  entityName   String
  conditionMet Boolean
  actionTaken  String?
  result       String?
  details      String?
  executedAt   DateTime @default(now())
  
  rule         Rule      @relation(fields: [ruleId], references: [id])
  adAccount    AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([ruleId])
  @@index([adAccountId, executedAt])
  @@index([entityType, entityId])
}

// AI рекомендация
model AIRecommendation {
  id                 String   @id @default(cuid())
  adAccountId        String
  entityType         String
  entityId           String
  entityName         String
  recommendationType String   // pause, enable, budget_change, bid_change
  details            String   // JSON с деталями
  confidence         Float    @default(0)
  isAccepted         Boolean? // null = pending, true = accepted, false = rejected
  createdAt          DateTime @default(now())
  
  adAccount          AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([adAccountId, createdAt])
  @@index([isAccepted])
}

// AI действие (полный режим)
model AIAction {
  id          String   @id @default(cuid())
  adAccountId String
  entityType  String
  entityId    String
  entityName  String
  actionType  String   // pause, enable, budget_change, bid_change
  parameters  String   // JSON с параметрами
  reason      String
  status      String   @default("pending") // pending, executed, failed, cancelled
  result      String?
  createdAt   DateTime @default(now())
  executedAt  DateTime?
  
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([adAccountId, createdAt])
  @@index([status])
}

// Данные аппрувов (ручной ввод или постбеки)
model ApproveData {
  id          String   @id @default(cuid())
  adAccountId String
  source      String   // manual, postback
  externalId  String?  // ID из внешней системы
  amount      Float
  currency    String   @default("USD")
  campaignId  String?
  adSetId     String?
  adId        String?
  approvedAt  DateTime @map("approved_at")
  createdAt   DateTime @default(now())
  
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([adAccountId, approvedAt])
  @@index([campaignId])
  @@index([adSetId])
  @@index([adId])
}
