generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String?
  password            String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ruleTemplates       RuleTemplate[]

  facebookConnections FacebookConnection[]
}

model FacebookConnection {
  id                String   @id @default(cuid())
  userId            String
  facebookUserId    String   @unique @map("facebook_user_id")
  facebookName      String   @map("facebook_name")
  facebookEmail     String?  @map("facebook_email")
  accessToken       String   @map("access_token")
  tokenExpiresAt    DateTime @map("token_expires_at")
  status            String   @default("active") // active, expired, banned, disconnected, archived
  aiEnabled         Boolean  @default(false) @map("ai_enabled")
  aiMode            String   @default("off") @map("ai_mode") // off, recommend, auto
  connectedAt       DateTime @default(now()) @map("connected_at")
  lastSyncedAt      DateTime? @map("last_synced_at")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User        @relation(fields: [userId], references: [id])
  adAccounts        AdAccount[]

  @@index([userId])
  @@index([status])
}

model AdAccount {
  id                   String   @id @default(cuid())
  facebookConnectionId String   @map("facebook_connection_id")
  accountId            String   @unique // act_XXX
  name                 String
  timezone             String   @default("UTC")
  status               String   @default("active") // active, disabled, banned, archived

  currency             String?
  billingStatus        String?  @map("billing_status") // ok, restricted, unpaid, unknown
  billingCountry       String?  @map("billing_country")
  spendCap             Float?   @map("spend_cap")

  paymentMethodLabel   String?  @map("payment_method_label") // Visa •••• 4242
  paymentMethodType    String?  @map("payment_method_type")  // visa, mastercard, paypal, unknown
  paymentMethodStatus  String?  @map("payment_method_status") // active, failed, disabled, unknown

  aiEnabled            Boolean  @default(false) @map("ai_enabled")
  aiMode               String   @default("off") @map("ai_mode") // off, recommend, auto
  aiLastCheckAt        DateTime? @map("ai_last_check_at")

  lastSyncedAt         DateTime? @map("last_synced_at")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  facebookConnection   FacebookConnection @relation(fields: [facebookConnectionId], references: [id])

  campaigns            Campaign[]
  adSets               AdSet[]
  ads                  Ad[]
  metrics              MetricSnapshot[]
  rules                Rule[]
  ruleExecutions       RuleExecution[]
  aiRecommendations    AIRecommendation[]
  aiActions            AIAction[]
  approveData          ApproveData[]
  campaignRules          CampaignRule[]
  campaignRuleExecutions CampaignRuleExecution[]

  @@index([facebookConnectionId])
  @@index([status])
  @@index([billingStatus])
}

// Кампания
model Campaign {
  id           String   @id @default(cuid())
  adAccountId  String
  campaignId   String   @unique
  name         String
  status       String
  objective    String?
  createdTime  DateTime
  updatedTime  DateTime
  createdAt    DateTime @default(now())

  adAccount    AdAccount @relation(fields: [adAccountId], references: [id])
  adSets       AdSet[]

  @@index([adAccountId])
  @@index([campaignId])
}

model AdSet {
  id          String   @id @default(cuid())
  adAccountId String
  campaignId  String
  adSetId     String   @unique
  name        String
  status      String
  budget      Float?
  bidStrategy String?
  createdTime DateTime
  updatedTime DateTime
  createdAt   DateTime @default(now())

  adAccount   AdAccount @relation(fields: [adAccountId], references: [id])
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  ads         Ad[]

  @@index([adAccountId])
  @@index([campaignId])
  @@index([adSetId])
}

model Ad {
  id          String   @id @default(cuid())
  adAccountId String
  adSetId     String
  adId        String   @unique
  name        String
  status      String
  creativeUrl String?
  createdTime DateTime
  updatedTime DateTime
  createdAt   DateTime @default(now())

  adAccount   AdAccount @relation(fields: [adAccountId], references: [id])
  adSet       AdSet     @relation(fields: [adSetId], references: [id])

  @@index([adAccountId])
  @@index([adSetId])
  @@index([adId])
}

// Снимок метрик (кэш статистики)
model MetricSnapshot {
  id           String   @id @default(cuid())
  adAccountId  String
  entityType   String   // account, campaign, adset, ad
  entityId     String   // ID сущности
  entityName   String   // Имя для отображения
  
  // Метрики из Facebook
  spend        Float    @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  ctr          Float    @default(0) // Click-through rate
  cpc          Float    @default(0) // Cost per click
  cpm          Float    @default(0) // Cost per 1000 impressions
  
  // Конверсии
  leads        Int      @default(0)
  conversions  Int      @default(0)
  cpl          Float    @default(0) // Cost per lead
  cpa          Float    @default(0) // Cost per action/conversion
  
  // Доходность
  revenue      Float    @default(0)
  roas         Float    @default(0) // Return on ad spend
  roi          Float    @default(0) // Return on investment
  
  // Аппрувы (ручной ввод)
  approves     Int      @default(0)
  cpas         Float    @default(0) // Cost per approve
  
  date         DateTime // Дата снимка
  createdAt    DateTime @default(now())
  
  adAccount    AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([adAccountId, entityType, entityId])
  @@index([adAccountId, date])
  @@index([entityType, entityId, date])
}

// Правило автоматизации
model Rule {
  id              String   @id @default(cuid())
  adAccountId     String
  name            String
  description     String?
  entityType      String   // ad, adset, campaign
  condition       String   // JSON с условием
  action          String   // pause, enable, budget_change, bid_change
  actionParams    String?  // JSON с параметрами действия
  threshold       Float?
  cooldownMinutes Int      @default(60)
  isActive        Boolean  @default(true)
  lastExecutedAt  DateTime? @map("last_executed_at")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  adAccount       AdAccount       @relation(fields: [adAccountId], references: [id])
  ruleExecutions  RuleExecution[]
  
  @@index([adAccountId])
  @@index([isActive])
}

// Лог выполнения правила
model RuleExecution {
  id           String   @id @default(cuid())
  ruleId       String
  adAccountId  String
  entityType   String
  entityId     String
  entityName   String
  conditionMet Boolean
  actionTaken  String?
  result       String?
  details      String?
  executedAt   DateTime @default(now())
  
  rule         Rule      @relation(fields: [ruleId], references: [id])
  adAccount    AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([ruleId])
  @@index([adAccountId, executedAt])
  @@index([entityType, entityId])
}

model RuleTemplate {
  id              String   @id @default(cuid())
  userId          String
  name            String
  offerName       String
  payout          Float
  approveRate     Float    // 20 = 20%
  targetRoi       Float    // 50 = 50%
  actionScope     String   // ad, adset
  actionType      String   // pause, enable
  cooldownMinutes Int      @default(60)
  isActive        Boolean  @default(true)

  sourceType      String   @default("manual") // manual, pp_api
  externalOfferId String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  campaignRules   CampaignRule[]

  @@index([userId])
  @@index([isActive])
}

model CampaignRule {
  id                     String   @id @default(cuid())
  adAccountId            String
  campaignId             String
  campaignName           String
  ruleTemplateId         String

  payout                 Float
  approveRate            Float
  targetRoi              Float
  calculatedCplThreshold Float

  actionScope            String   // ad, adset
  actionType             String   // pause, enable

  isActive               Boolean  @default(true)
  lastExecutedAt         DateTime?
  lastEvaluationAt       DateTime?
  lastResult             String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  adAccount              AdAccount        @relation(fields: [adAccountId], references: [id])
  ruleTemplate           RuleTemplate     @relation(fields: [ruleTemplateId], references: [id])
  executions             CampaignRuleExecution[]

  @@index([adAccountId])
  @@index([campaignId])
  @@index([ruleTemplateId])
  @@index([isActive])
}

model CampaignRuleExecution {
  id             String   @id @default(cuid())
  campaignRuleId String
  adAccountId    String
  campaignId     String
  entityType     String   // ad, adset
  entityId       String
  entityName     String

  realCpl        Float?
  thresholdCpl   Float?
  actionTaken    String?
  result         String?
  details        String?
  executedAt     DateTime @default(now())

  campaignRule   CampaignRule @relation(fields: [campaignRuleId], references: [id])
  adAccount      AdAccount    @relation(fields: [adAccountId], references: [id])

  @@index([campaignRuleId])
  @@index([adAccountId, executedAt])
  @@index([campaignId])
}

// AI рекомендация
model AIRecommendation {
  id                 String   @id @default(cuid())
  adAccountId        String
  entityType         String
  entityId           String
  entityName         String
  recommendationType String   // pause, enable, budget_change, bid_change
  details            String   // JSON с деталями
  confidence         Float    @default(0)
  isAccepted         Boolean? // null = pending, true = accepted, false = rejected
  createdAt          DateTime @default(now())
  
  adAccount          AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([adAccountId, createdAt])
  @@index([isAccepted])
}

// AI действие (полный режим)
model AIAction {
  id          String   @id @default(cuid())
  adAccountId String
  entityType  String
  entityId    String
  entityName  String
  actionType  String   // pause, enable, budget_change, bid_change
  parameters  String   // JSON с параметрами
  reason      String
  status      String   @default("pending") // pending, executed, failed, cancelled
  result      String?
  createdAt   DateTime @default(now())
  executedAt  DateTime?
  
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([adAccountId, createdAt])
  @@index([status])
}

// Данные аппрувов (ручной ввод или постбеки)
model ApproveData {
  id          String   @id @default(cuid())
  adAccountId String
  source      String   // manual, postback
  externalId  String?  // ID из внешней системы
  amount      Float
  currency    String   @default("USD")
  campaignId  String?
  adSetId     String?
  adId        String?
  approvedAt  DateTime @map("approved_at")
  createdAt   DateTime @default(now())
  
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id])
  
  @@index([adAccountId, approvedAt])
  @@index([campaignId])
  @@index([adSetId])
  @@index([adId])
}
